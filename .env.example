# MongoDB Connection String
MONGO=mongodb://localhost:27017/chronova

# JWT Secret Key (generate a secure random string)
JWT_SECRET=your_jwt_secret_key_here

# Server Port (optional, defaults to 5000)
PORT=5000

# Node Environment (development or production)
NODE_ENV=development

# eSewa Payment Gateway Configuration
# For testing: use EPAYTEST with test credentials
# For production: use your actual eSewa merchant credentials
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_FORM_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_URL=https://rc-epay.esewa.com.np/api/epay/transaction/status/

# Enable mock mode for local development (bypasses actual eSewa gateway)
# Set to 'true' to simulate successful eSewa payments without real payment gateway
ESEWA_MOCK_MODE=true

# Frontend URL (used for eSewa callbacks)
FRONTEND_URL=http://localhost:5173
